{
  "manifest_version": 3,
  "name": "MemeFocus Companion Blocker",
  "version": "1.0",
  "description": "Blocks distracting websites and redirects to roasts and memes during Pomodoro focus sessions.",
  "permissions": [
    "tabs",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://memefocus-backend.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://*.vercel.app/*",
        "https://*.onrender.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
